NEXT_PUBLIC_REWARD_ENGINE_ADDRESS=
NEXT_PUBLIC_IDENTITY_NFT_ADDRESS=
NEXT_PUBLIC_GOVERNANCE_ADDRESS=
NEXT_PUBLIC_MARKETPLACE_ADDRESS=

# Snowtrace (for contract verification)
SNOWTRACE_API_KEY=

# IPFS / Pinata (optional — for NFT metadata)
