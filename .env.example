# Avalanche RPC
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVAX_WS_URL=wss://api.avax.network/ext/bc/C/ws
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
FUJI_WS_URL=wss://api.avax-test.network/ext/bc/C/ws

# Contract Addresses (set after deployment)
QUEST_REGISTRY_ADDRESS=
PLAYER_PROGRESS_ADDRESS=
PROOF_VALIDATOR_ADDRESS=
REWARD_ENGINE_ADDRESS=
IDENTITY_NFT_ADDRESS=
GOVERNANCE_ADDRESS=
MARKETPLACE_ADDRESS=

# Proof Signer (KEEP SECRET)
PROOF_SIGNER_PRIVATE_KEY=

# Deployer
DEPLOYER_PRIVATE_KEY=

# Database
DATABASE_URL=postgresql://arena:arena@localhost:5432/avalanche_arena

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_URL=http://localhost:3001
JWT_SECRET=change-this-in-production

# Frontend
NEXT_PUBLIC_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CHAIN_ID=43113
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
